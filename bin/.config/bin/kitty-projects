#!/usr/bin/env bash

## cmd + 0

if [[ $# -eq 1 ]]; then
  selected=$1
else
  selected=$(find ~/work ~/work/tmp ~/private ~/work/Okode ~/dotfiles ~/.local/share/nvim/lazy ~/Downloads ~ -mindepth 1 -maxdepth 1 -type d | fzf --bind=ctrl-k:up,ctrl-j:down)
fi

selected_name=$(echo "$selected" | sed 's/ /\\ /g')

if [[ -z $selected ]]; then
  exit 0
fi

kitty @ send-text "cd $(printf '%q' "$selected")\r"

# tmux previous-window
# tmux split-pane -h
# tmux send-keys -t 1 "cd $selected && clear" C-m
